# KYBER environment configuration.
# Copy of this file is made automatically by install.sh -> .env
# Most of these get filled in for real by the onboarding wizard
# (http://<hostname>.local:5001) rather than by hand -- this file just
# needs to exist with sane defaults so the services can start.

# --- Droid identity (set by the Claim step in the onboarding wizard) ---
DROID_MAC=
DROID_NAME=
DROID_TYPE=R
# One of: R, BB, C, A, BD

# --- Provider selection (changeable later via the Logic Core Connections panel) ---
LLM_PROVIDER=gemini
# One of: gemini, openai, anthropic, groq
STT_PROVIDER=deepgram
# One of: deepgram, groq, openai, google, assemblyai

# --- API keys (only the ones for your chosen providers above are required) ---
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=
DEEPGRAM_API_KEY=
ASSEMBLYAI_API_KEY=
GOOGLE_STT_API_KEY=

# --- Microphone ---
MIC_DEVICE=pipewire
MIC_DEVICE_FALLBACK=pipewire

# --- Personality / sound profile slots (set via Mainframe, not by hand) ---
ACTIVE_PERSONALITY=1
ACTIVE_SOUND_PROFILE=1

# --- Motor calibration (set via the Calibration wizard, not by hand) ---
CALIBRATION_LEFT_SCALE=1.0
CALIBRATION_RIGHT_SCALE=1.0

# --- Feature flags ---
BEACON_RELAY_ENABLED=true
ROAM_MODE_ENABLED=false
